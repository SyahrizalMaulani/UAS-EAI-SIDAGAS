# Database Credentials
MYSQL_USER=sidagas_user
MYSQL_PASSWORD=sidagas_pass
MYSQL_ROOT_PASSWORD=root_pass

# Service Ports
PORT_GATEWAY=3000
PORT_ORDER=3001
PORT_INVENTORY=3002
