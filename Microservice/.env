# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:5672

# Database URLs (for internal container use)
DB_HOST_ORDER=order-db
DB_HOST_INVENTORY=inventory-db
DB_HOST_DELIVERY=delivery-db
DB_HOST_FINANCE=finance-db
